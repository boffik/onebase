// Проведение «Задача CRM» — движение в регистр ВыполнениеЗадач.

Процедура ОбработкаПроведения()
  Движения.ВыполнениеЗадач.Очистить();

  Дв = Движения.ВыполнениеЗадач.Добавить();
  Дв.Исполнитель = this.Исполнитель;
  Дв.Статус      = this.Статус;
  Дв.Количество  = 1;
  Если ЗначениеЗаполнено(this.Сделка) Тогда
    Дв.Сделка    = this.Сделка;
  КонецЕсли;
  Дв.Клиент      = this.Клиент;
КонецПроцедуры
