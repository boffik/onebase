// Проведение «Оплата» — движение в регистр ОплатыКлиентов.

Процедура ОбработкаПроведения()
  Движения.ОплатыКлиентов.Очистить();

  Дв = Движения.ОплатыКлиентов.Добавить();
  Дв.Клиент        = this.Клиент;
  Дв.Сделка        = this.Сделка;
  Дв.Сумма         = this.Сумма;
  Дв.Ответственный = this.Ответственный;
  Дв.СпособОплаты  = this.СпособОплаты;
КонецПроцедуры
