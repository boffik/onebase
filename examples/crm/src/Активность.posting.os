// Проведение «Активность» — движение в регистр Взаимодействия.

Процедура ОбработкаПроведения()
  Движения.Взаимодействия.Очистить();

  Дв = Движения.Взаимодействия.Добавить();
  Дв.Клиент            = this.Клиент;
  Дв.ТипАктивности     = this.ТипАктивности;
  Дв.Ответственный     = this.Ответственный;
  Дв.Количество        = 1;
  Дв.ДлительностьМинут = this.ДлительностьМинут;
  Если ЗначениеЗаполнено(this.Сделка) Тогда
    Дв.Сделка          = this.Сделка;
  КонецЕсли;
КонецПроцедуры
