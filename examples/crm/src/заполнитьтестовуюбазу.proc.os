    Зап.Фамилия       = "Хитрая";
    Зап.Имя           = "Ольга";
    Зап.Должность     = "Жена и главный бухгалтер ИП Хитрый";
    Зап.Телефон       = "+7 (916) 222-22-22";
    Зап.Клиент        = КлиентХитрый;
    Зап.ОсновнойКонтакт = Истина;
    Зап.ДатаРождения = Дата(1990, 2, 14);
    Зап.Записать();
  КонецЕсли;
  КонтактОльга = Справочники.КонтактноеЛицо.НайтиПоНаименованию("Хитрая Ольга");

  Если ЗначениеЗаполнено(Справочники.КонтактноеЛицо.НайтиПоНаименованию("Котова Мяуслава")) = Ложь Тогда
    Зап = Справочники.КонтактноеЛицо.Создать();
    Зап.Наименование  = "Котова Мяуслава";
    Зап.Фамилия       = "Котова";
    Зап.Имя           = "Мяуслава";
    Зап.Должность     = "Директор по развитию (и сну)";
    Зап.Email         = "meow@vsekoty.ru";
    Зап.Клиент        = КлиентКоты;
    Зап.ОсновнойКонтакт = Истина;
    Зап.ДатаРождения = Дата(1988, 11, 3);
    Зап.Записать();
  КонецЕсли;
  КонтактМяуслава = Справочники.КонтактноеЛицо.НайтиПоНаименованию("Котова Мяуслава");

  Если ЗначениеЗаполнено(Справочники.КонтактноеЛицо.НайтиПоНаименованию("Строев Камаз")) = Ложь Тогда
    Зап = Справочники.КонтактноеЛицо.Создать();
    Зап.Наименование  = "Строев Камаз";
    Зап.Фамилия       = "Строев";
    Зап.Имя           = "Камаз";
    Зап.Должность     = "Прораб (и по совместительству зам. директора)";
    Зап.Телефон       = "+7 (916) 444-44-44";
    Зап.Клиент        = КлиентСтрой;
    Зап.ОсновнойКонтакт = Истина;
    Зап.ДатаРождения = Дата(1978, 5, 9);
    Зап.Записать();
  КонецЕсли;
  КонтактКамаз = Справочники.КонтактноеЛицо.НайтиПоНаименованию("Строев Камаз");

  Сообщить("Справочники готовы.");

  // ============ ОЧИСТКА ДОКУМЕНТОВ ============

  Очищаем = (Параметры.Очистить <> Ложь);
  Если Очищаем Тогда
    Удал = 0;
    Попытка
      // Сначала удаляем документы, ссылающиеся на Сделка (FK),
      // затем — саму Сделку, иначе FOREIGN KEY constraint failed.
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.Оплата";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.Оплата.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.Оплата.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.КоммерческоеПредложение";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.КоммерческоеПредложение.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.КоммерческоеПредложение.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.ЗадачаCRM";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.ЗадачаCRM.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.ЗадачаCRM.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.Звонок";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.Звонок.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.Звонок.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.Активность";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.Активность.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.Активность.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      ЗД = Новый Запрос; ЗД.Текст = "ВЫБРАТЬ Номер ИЗ Документ.Сделка";
      Для Каждого Стр Из ЗД.Выполнить() Цикл
        Об = Документы.Сделка.НайтиПоНомеру(Стр.Номер);
        Если ЗначениеЗаполнено(Об) Тогда Документы.Сделка.Удалить(Об); Удал = Удал + 1; КонецЕсли;
      КонецЦикла;
      Сообщить("Очищено документов: " + Строка(Удал));
    Исключение
      Сообщить("Очистка не выполнена: " + ОписаниеОшибки());
    КонецПопытки;
  КонецЕсли;

  ЗСд = Новый Запрос; ЗСд.Текст = "ВЫБРАТЬ Номер ИЗ Документ.Сделка";
  ЕстьСд = Ложь;
  Для Каждого Д Из ЗСд.Выполнить() Цикл ЕстьСд = Истина; Прервать; КонецЦикла;
  Создавать = (ЕстьСд = Ложь);

  // ============ СОЗДАНИЕ И ПРОВЕДЕНИЕ ============

  Если Создавать Тогда
    Сегодня = ТекущаяДата();
