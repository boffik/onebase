// Наполняет тестовую базу «CRM-безумия» с проведением, в один проход.
//
// Параметр «Очистить» (bool, по умолчанию true):
//   при очистке удаляются все документы, затем база наполняется заново.
//
// Идемпотентно: справочники — по наименованию; документы создаются, только
// если очистка прошла ИЛИ сделок ещё нет.
//
// Тематика: компания «Дожмём-Сервис» — где каждый клиент — это шанс,
// а каждый звонок — маленькая победа.

Процедура Выполнить()

  // ============ СПРАВОЧНИКИ ============

  // --- Сотрудники ---

  Если ЗначениеЗаполнено(Справочники.Сотрудник.НайтиПоНаименованию("Дожимов Аркадий Продаватович")) = Ложь Тогда
    Зап = Справочники.Сотрудник.Создать();
    Зап.Наименование = "Дожимов Аркадий Продаватович";
    Зап.Должность    = "Директор по продажам";
    Зап.Email        = "dozhimov@dognem-service.ru";
    Зап.Телефон      = "+7 (495) 100-00-01";
    Зап.Отдел        = "Продажи";
    Зап.Активный     = Истина;
    Зап.ДатаПриёмаНаРаботу = Дата(2020, 3, 15);
    Зап.Записать();
  КонецЕсли;
  СотрДиректор = Справочники.Сотрудник.НайтиПоНаименованию("Дожимов Аркадий Продаватович");

  Если ЗначениеЗаполнено(Справочники.Сотрудник.НайтиПоНаименованию("Звонилкина Светлана")) = Ложь Тогда
    Зап = Справочники.Сотрудник.Создать();
    Зап.Наименование = "Звонилкина Светлана";
    Зап.Должность    = "Менеджер по холодным звонкам";
    Зап.Email        = "zvonilkina@dognem-service.ru";
    Зап.Телефон      = "+7 (495) 100-00-02";
    Зап.Отдел        = "Продажи";
    Зап.Активный     = Истина;
    Зап.ДатаПриёмаНаРаботу = Дата(2022, 6, 1);
    Зап.Записать();
  КонецЕсли;
  СотрМенеджер1 = Справочники.Сотрудник.НайтиПоНаименованию("Звонилкина Светлана");

  Если ЗначениеЗаполнено(Справочники.Сотрудник.НайтиПоНаименованию("Уговорова Марина")) = Ложь Тогда
    Зап = Справочники.Сотрудник.Создать();
    Зап.Наименование = "Уговорова Марина";
    Зап.Должность    = "Account Manager";
    Зап.Email        = "ugovorova@dognem-service.ru";
    Зап.Телефон      = "+7 (495) 100-00-03";
    Зап.Отдел        = "Продажи";
    Зап.Активный     = Истина;
    Зап.ДатаПриёмаНаРаботу = Дата(2021, 9, 10);
    Зап.Записать();
  КонецЕсли;
  СотрАккаунт = Справочники.Сотрудник.НайтиПоНаименованию("Уговорова Марина");

  Если ЗначениеЗаполнено(Справочники.Сотрудник.НайтиПоНаименованию("Презентов Олег")) = Ложь Тогда
    Зап = Справочники.Сотрудник.Создать();
    Зап.Наименование = "Презентов Олег";
    Зап.Должность    = "Пресейл-инженер";
    Зап.Email        = "prezentov@dognem-service.ru";
    Зап.Телефон      = "+7 (495) 100-00-04";
    Зап.Отдел        = "Пресейл";
    Зап.Активный     = Истина;
    Зап.ДатаПриёмаНаРаботу = Дата(2023, 1, 20);
    Зап.Записать();
  КонецЕсли;
  СотрПресейл = Справочники.Сотрудник.НайтиПоНаименованию("Презентов Олег");

  Если ЗначениеЗаполнено(Справочники.Сотрудник.НайтиПоНаименованию("Смирнова Татьяна")) = Ложь Тогда
    Зап = Справочники.Сотрудник.Создать();
    Зап.Наименование = "Смирнова Татьяна";
    Зап.Должность    = "Customer Success Manager";
    Зап.Email        = "smirnova@dognem-service.ru";
    Зап.Телефон      = "+7 (495) 100-00-05";
    Зап.Отдел        = "Поддержка";
    Зап.Активный     = Истина;
    Зап.ДатаПриёмаНаРаботу = Дата(2022, 11, 5);
    Зап.Записать();
  КонецЕсли;
  СотрПоддержка = Справочники.Сотрудник.НайтиПоНаименованию("Смирнова Татьяна");

  // --- Воронки и стадии ---

  Если ЗначениеЗаполнено(Справочники.Воронка.НайтиПоНаименованию("Воронка тотального отчаяния")) = Ложь Тогда
    Зап = Справочники.Воронка.Создать();
    Зап.Наименование = "Воронка тотального отчаяния";
    Зап.Описание     = "Основная воронка продаж. От надежды до разочарования — за 5 стадий";
    Зап.Записать();
  КонецЕсли;
  ВоронкаОсн = Справочники.Воронка.НайтиПоНаименованию("Воронка тотального отчаяния");

  // Стадии
  СтадииСоздать = Новый Массив();
  // Формат: Наименование|Порядок|Вероятность|Цвет
  СтадииСоздать.Добавить("Первый контакт (клиент ещё не знает)|10|10|#AAAAAA");
  СтадииСоздать.Добавить("Квалификация (поняли, что у клиента есть деньги)|20|25|#4ECDC4");
  СтадииСоздать.Добавить("Коммерческое предложение (цензурная версия)|30|50|#FFE66D");
  СтадииСоздать.Добавить("Переговоры (клиент торгуется за копейки)|40|70|#FF6B6B");
  СтадииСоздать.Добавить("Согласование договора (юристы в шоке)|50|85|#C44D58");
  СтадииСоздать.Добавить("Успешная реализация (чудо произошло!)|60|100|#2ECC71");
  СтадииСоздать.Добавить("Закрыто и не реализовано (ну и ладно)|70|0|#95A5A6");
  Для Инд = 0 По СтадииСоздать.Количество() - 1 Цикл
    СтрСт = СтадииСоздать.Получить(Инд);
    ИмяСт = СтрПолучитьСтроку(СтрСт, 1);
    Если ЗначениеЗаполнено(Справочники.СтадияСделки.НайтиПоНаименованию(ИмяСт)) = Ложь Тогда
      Зап = Справочники.СтадияСделки.Создать();
      Зап.Наименование = ИмяСт;
      Зап.Воронка      = ВоронкаОсн;
      Зап.Порядок      = Число(СтрПолучитьСтроку(СтрСт, 2));
      Зап.Вероятность  = Число(СтрПолучитьСтроку(СтрСт, 3));
      Зап.Цвет         = СтрПолучитьСтроку(СтрСт, 4);
      Зап.Записать();
    КонецЕсли;
  КонецЦикла;

  СтадияКонтакт   = Справочники.СтадияСделки.НайтиПоНаименованию("Первый контакт (клиент ещё не знает)");
  СтадияКвал      = Справочники.СтадияСделки.НайтиПоНаименованию("Квалификация (поняли, что у клиента есть деньги)");
  СтадияКП        = Справочники.СтадияСделки.НайтиПоНаименованию("Коммерческое предложение (цензурная версия)");
  СтадияПереговоры = Справочники.СтадияСделки.НайтиПоНаименованию("Переговоры (клиент торгуется за копейки)");
  СтадияСоглас    = Справочники.СтадияСделки.НайтиПоНаименованию("Согласование договора (юристы в шоке)");
  СтадияУспех     = Справочники.СтадияСделки.НайтиПоНаименованию("Успешная реализация (чудо произошло!)");
  СтадияПровал    = Справочники.СтадияСделки.НайтиПоНаименованию("Закрыто и не реализовано (ну и ладно)");

  // --- Типы активности ---

  Если ЗначениеЗаполнено(Справочники.ТипАктивности.НайтиПоНаименованию("Звонок")) = Ложь Тогда
    Зап = Справочники.ТипАктивности.Создать();
    Зап.Наименование = "Звонок";
    Зап.Значок       = "📞";
    Зап.Записать();
  КонецЕсли;

  Если ЗначениеЗаполнено(Справочники.ТипАктивности.НайтиПоНаименованию("Встреча")) = Ложь Тогда
    Зап = Справочники.ТипАктивности.Создать();
    Зап.Наименование = "Встреча";
    Зап.Значок       = "🤝";
    Зап.Записать();
  КонецЕсли;

  Если ЗначениеЗаполнено(Справочники.ТипАктивности.НайтиПоНаименованию("Email")) = Ложь Тогда
    Зап = Справочники.ТипАктивности.Создать();
    Зап.Наименование = "Email";
    Зап.Значок       = "📧";
    Зап.Записать();
  КонецЕсли;

  Если ЗначениеЗаполнено(Справочники.ТипАктивности.НайтиПоНаименованию("Демонстрация")) = Ложь Тогда
    Зап = Справочники.ТипАктивности.Создать();
    Зап.Наименование = "Демонстрация";
    Зап.Значок       = "🖥️";
    Зап.Записать();
  КонецЕсли;

  ТипЗвонок   = Справочники.ТипАктивности.НайтиПоНаименованию("Звонок");
  ТипВстреча  = Справочники.ТипАктивности.НайтиПоНаименованию("Встреча");
  ТипEmail    = Справочники.ТипАктивности.НайтиПоНаименованию("Email");
  ТипДемо     = Справочники.ТипАктивности.НайтиПоНаименованию("Демонстрация");

  // --- Каналы связи ---

  Если ЗначениеЗаполнено(Справочники.КаналСвязи.НайтиПоНаименованию("Телефон")) = Ложь Тогда
    Зап = Справочники.КаналСвязи.Создать();
    Зап.Наименование = "Телефон";
    Зап.Описание     = "Старый добрый телефон — клиент не может закрыть вкладку";
    Зап.Записать();
  КонецЕсли;
  КанТелефон = Справочники.КаналСвязи.НайтиПоНаименованию("Телефон");

  Если ЗначениеЗаполнено(Справочники.КаналСвязи.НайтиПоНаименованию("Email")) = Ложь Тогда
    Зап = Справочники.КаналСвязи.Создать();
    Зап.Наименование = "Email";
    Зап.Описание     = "Письма уходят в спам, но мы не сдаёмся";
    Зап.Записать();
  КонецЕсли;
  КанEmail = Справочники.КаналСвязи.НайтиПоНаименованию("Email");

  Если ЗначениеЗаполнено(Справочники.КаналСвязи.НайтиПоНаименованию("WhatsApp")) = Ложь Тогда
    Зап = Справочники.КаналСвязи.Создать();
    Зап.Наименование = "WhatsApp";
    Зап.Описание     = "Читайте по голубой галочке — клиент точно увидел (и точно проигнорировал)";
    Зап.Записать();
  КонецЕсли;
  КанWhatsApp = Справочники.КаналСвязи.НайтиПоНаименованию("WhatsApp");

  // --- Клиенты ---

  Если ЗначениеЗаполнено(Справочники.Клиент.НайтиПоНаименованию("ООО «Ну Купи Уже»")) = Ложь Тогда
    Зап = Справочники.Клиент.Создать();
    Зап.Наименование       = "ООО «Ну Купи Уже»";
    Зап.ПолноеНаименование = "ООО «Ну Купи Уже»";
    Зап.ТипКлиента         = "Компания";
    Зап.ИНН                = "7701111222";
    Зап.Email              = "info@nukupi.ru";
    Зап.Телефон            = "+7 (495) 200-01-01";
    Зап.Ответственный      = СотрМенеджер1;
    Зап.Отрасль            = "Розничная торговля";
    Зап.Статус             = "Активный";
    Зап.ИсточникКлиента    = "Рекомендация";
    Зап.ДатаРегистрации    = Дата(2025, 1, 15);
    Зап.Записать();
  КонецЕсли;
  КлиентНуКупи = Справочники.Клиент.НайтиПоНаименованию("ООО «Ну Купи Уже»");

  Если ЗначениеЗаполнено(Справочники.Клиент.НайтиПоНаименованию("ИП Хитрый В.И.")) = Ложь Тогда
    Зап = Справочники.Клиент.Создать();
    Зап.Наименование       = "ИП Хитрый В.И.";
    Зап.ПолноеНаименование = "Индивидуальный предприниматель Хитрый Владимир Иванович";
    Зап.ТипКлиента         = "Физлицо";
    Зап.Телефон            = "+7 (916) 300-02-02";
    Зап.Ответственный      = СотрАккаунт;
    Зап.Отрасль            = "Услуги";
    Зап.Статус             = "Активный";
    Зап.ИсточникКлиента    = "ХолодныйЗвонок";
    Зап.ДатаРегистрации    = Дата(2025, 3, 22);
    Зап.Записать();
  КонецЕсли;
  КлиентХитрый = Справочники.Клиент.НайтиПоНаименованию("ИП Хитрый В.И.");

  Если ЗначениеЗаполнено(Справочники.Клиент.НайтиПоНаименованию("ЗАО «ТехноПараноик»")) = Ложь Тогда
    Зап = Справочники.Клиент.Создать();
    Зап.Наименование       = "ЗАО «ТехноПараноик»";
    Зап.ПолноеНаименование = "ЗАО «ТехноПараноик»";
    Зап.ТипКлиента         = "Компания";
    Зап.ИНН                = "7702333444";
    Зап.Email              = "paranoia@techno.ru";
    Зап.Телефон            = "+7 (495) 300-03-03";
    Зап.Ответственный      = СотрПресейл;
    Зап.Отрасль            = "IT";
    Зап.Статус             = "Потенциальный";
    Зап.ИсточникКлиента    = "Выставка";
    Зап.ДатаРегистрации    = Дата(2025, 8, 10);
    Зап.Записать();
  КонецЕсли;
  КлиентТехно = Справочники.Клиент.НайтиПоНаименованию("ЗАО «ТехноПараноик»");

  Если ЗначениеЗаполнено(Справочники.Клиент.НайтиПоНаименованию("ООО «Всё для котов»")) = Ложь Тогда
    Зап = Справочники.Клиент.Создать();
    Зап.Наименование       = "ООО «Всё для котов»";
    Зап.ПолноеНаименование = "ООО «Всё для котов»";
    Зап.ТипКлиента         = "Компания";
    Зап.ИНН                = "7703555666";
    Зап.Email              = "meow@vsekoty.ru";
    Зап.Телефон            = "+7 (495) 400-04-04";
    Зап.Ответственный      = СотрАккаунт;
    Зап.Отрасль            = "Зообизнес";
    Зап.Статус             = "Активный";
    Зап.ИсточникКлиента    = "Сайт";
    Зап.ДатаРегистрации    = Дата(2025, 5, 7);
    Зап.Записать();
  КонецЕсли;
  КлиентКоты = Справочники.Клиент.НайтиПоНаименованию("ООО «Всё для котов»");

  Если ЗначениеЗаполнено(Справочники.Клиент.НайтиПоНаименованию("ООО «Строй-Дожмём»")) = Ложь Тогда
    Зап = Справочники.Клиент.Создать();
    Зап.Наименование       = "ООО «Строй-Дожмём»";
    Зап.ПолноеНаименование = "ООО «Строй-Дожмём»";
    Зап.ТипКлиента         = "Компания";
    Зап.ИНН                = "7704777888";
    Зап.Email              = "stroy@dognem-stroy.ru";
    Зап.Телефон            = "+7 (495) 500-05-05";
    Зап.Ответственный      = СотрДиректор;
    Зап.Отрасль            = "Строительство";
    Зап.Статус             = "Активный";
    Зап.ИсточникКлиента    = "Рекомендация";
    Зап.ДатаРегистрации    = Дата(2025, 4, 18);
    Зап.Записать();
  КонецЕсли;
  КлиентСтрой = Справочники.Клиент.НайтиПоНаименованию("ООО «Строй-Дожмём»");

  Если ЗначениеЗаполнено(Справочники.Клиент.НайтиПоНаименованию("ООО «Мамина Радость»")) = Ложь Тогда
    Зап = Справочники.Клиент.Создать();
    Зап.Наименование       = "ООО «Мамина Радость»";
    Зап.ПолноеНаименование = "ООО «Мамина Радость»";
    Зап.ТипКлиента         = "Компания";
    Зап.ИНН                = "7705999000";
    Зап.Email              = "mama@radost.ru";
    Зап.Телефон            = "+7 (495) 600-06-06";
    Зап.Ответственный      = СотрПоддержка;
    Зап.Отрасль            = "Детские товары";
    Зап.Статус             = "Потенциальный";
    Зап.ИсточникКлиента    = "СоцСети";
    Зап.ДатаРегистрации    = Дата(2025, 9, 3);
    Зап.Записать();
  КонецЕсли;
  КлиентМамина = Справочники.Клиент.НайтиПоНаименованию("ООО «Мамина Радость»");

  // --- Контактные лица ---

  Если ЗначениеЗаполнено(Справочники.КонтактноеЛицо.НайтиПоНаименованию("Закупкин Стёпа")) = Ложь Тогда
    Зап = Справочники.КонтактноеЛицо.Создать();
    Зап.Наименование  = "Закупкин Стёпа";
    Зап.Фамилия       = "Закупкин";
    Зап.Имя           = "Степан";
    Зап.Должность     = "Начальник закупок";
    Зап.Телефон       = "+7 (916) 111-11-11";
    Зап.Клиент        = КлиентНуКупи;
    Зап.ОсновнойКонтакт = Истина;
    Зап.ДатаРождения = Дата(1985, 7, 20);
    Зап.Записать();
  КонецЕсли;
  КонтактСтёпа = Справочники.КонтактноеЛицо.НайтиПоНаименованию("Закупкин Стёпа");

  Если ЗначениеЗаполнено(Справочники.КонтактноеЛицо.НайтиПоНаименованию("Хитрая Ольга")) = Ложь Тогда
    Зап = Справочники.КонтактноеЛицо.Создать();
