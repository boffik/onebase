    Стр = Сд1.ТоварыУслуги.Добавить(); Стр.Номенклатура = "Лицензия CRM (10 пользователей)"; Стр.Количество = 1; Стр.Цена = 180000; Стр.Сумма = 180000;
    Стр = Сд1.ТоварыУслуги.Добавить(); Стр.Номенклатура = "Внедрение и обучение"; Стр.Количество = 1; Стр.Цена = 100000; Стр.Сумма = 100000;
    Стр = Сд1.Участники.Добавить(); Стр.Сотрудник = СотрАккаунт; Стр.Роль = "Менеджер";
    Сд1.Записать(); Сд1.Провести();
    Сд1 = Документы.Сделка.НайтиПоНомеру("СД-00001");

    // ---- СДЕЛКА 2: ТехноПараноик — ПРОВАЛЕНА (-4 мес) ----

