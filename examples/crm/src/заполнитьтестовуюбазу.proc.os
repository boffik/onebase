    Опл4.НазначениеПлатежа = "Оплата за CRM для мам. Прислали вместе с рисунком ребенка.";
    Опл4.Ответственный = СотрПоддержка;
    Опл4.Записать(); Опл4.Провести();

    Опл5 = Документы.Оплата.Создать();
    Опл5.Номер = "ОПЛ-00005";
    Опл5.Дата = Сегодня; Опл5.Клиент = КлиентНуКупи; Опл5.Сделка = Сд5;
    Опл5.Сумма = 225000;
    Опл5.СпособОплаты = "Безналичный";
    Опл5.НазначениеПлатежа = "Окончательная оплата. Шампанское закончилось, но радость осталась.";
    Опл5.Ответственный = СотрАккаунт;
    Опл5.Записать(); Опл5.Провести();

    Опл6 = Документы.Оплата.Создать();
    Опл6.Номер = "ОПЛ-00006";
    Опл6.Дата = Сегодня; Опл6.Клиент = КлиентНуКупи; Опл6.Сделка = Сд11;
    Опл6.Сумма = 350000;
    Опл6.СпособОплаты = "Безналичный";
    Опл6.НазначениеПлатежа = "Годовая подписка. Стёпа сказал: «Это лучшая инвестиция после кофемашины».";
    Опл6.Ответственный = СотрАккаунт;
    Опл6.Записать(); Опл6.Провести();

    Сообщить("Оплаты (6 шт.) проведены.");
    Сообщить("Все документы созданы и проведены.");
  Иначе
    Сообщить("Документы уже есть, очистка выключена — создание пропущено.");
  КонецЕсли;

  // ============ ИТОГОВАЯ СВОДКА ============

  ЗКл = Новый Запрос; ЗКл.Текст = "ВЫБРАТЬ Наименование ИЗ Клиент";
  КолКл = 0; Для Каждого Д Из ЗКл.Выполнить() Цикл КолКл = КолКл + 1; КонецЦикла;

  ЗСд = Новый Запрос; ЗСд.Текст = "ВЫБРАТЬ Номер ИЗ Документ.Сделка";
  КолСд = 0; Для Каждого Д Из ЗСд.Выполнить() Цикл КолСд = КолСд + 1; КонецЦикла;

  ЗЗв = Новый Запрос; ЗЗв.Текст = "ВЫБРАТЬ Номер ИЗ Документ.Звонок";
  КолЗв = 0; Для Каждого Д Из ЗЗв.Выполнить() Цикл КолЗв = КолЗв + 1; КонецЦикла;

  ЗАкт = Новый Запрос; ЗАкт.Текст = "ВЫБРАТЬ Номер ИЗ Документ.Активность";
  КолАкт = 0; Для Каждого Д Из ЗАкт.Выполнить() Цикл КолАкт = КолАкт + 1; КонецЦикла;

  ЗЗад = Новый Запрос; ЗЗад.Текст = "ВЫБРАТЬ Номер ИЗ Документ.ЗадачаCRM";
  КолЗад = 0; Для Каждого Д Из ЗЗад.Выполнить() Цикл КолЗад = КолЗад + 1; КонецЦикла;

  ЗОпл = Новый Запрос; ЗОпл.Текст = "ВЫБРАТЬ Номер ИЗ Документ.Оплата";
  КолОпл = 0; Для Каждого Д Из ЗОпл.Выполнить() Цикл КолОпл = КолОпл + 1; КонецЦикла;

  ЗКП = Новый Запрос; ЗКП.Текст = "ВЫБРАТЬ Номер ИЗ Документ.КоммерческоеПредложение";
  КолКП = 0; Для Каждого Д Из ЗКП.Выполнить() Цикл КолКП = КолКП + 1; КонецЦикла;

  Сообщить("Сводка: клиентов " + Строка(КолКл)
    + ", сделок " + Строка(КолСд)
    + ", звонков " + Строка(КолЗв)
    + ", активностей " + Строка(КолАкт)
    + ", задач " + Строка(КолЗад)
    + ", КП " + Строка(КолКП)
    + ", оплат " + Строка(КолОпл) + ".");

КонецПроцедуры
