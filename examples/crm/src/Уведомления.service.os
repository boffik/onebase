// Демо real-time-шины через HTTP-сервис (план 74). Поскольку это /hs/-эндпоинт,
// он гейтится предохранителем сети (план 62): включите «Разрешить сетевые
// операции» (Система → Настройки), иначе вернётся 503. Это та же схема, что у
// входящих вебхуков телефонии (план 75).
//   curl -X POST http://localhost:8080/hs/notify/broadcast -d "Привет из onebase"
// Без включения сети используйте обработку «Тест real-time уведомления».
Функция Рассылка(Запрос) Экспорт
    Текст = Запрос.ПолучитьТелоКакСтроку();
    Если Текст = "" Тогда
        Текст = "Тестовое уведомление";
    КонецЕсли;
    ОтправитьУведомление("*", "уведомление", Текст);
    Возврат Новый Структура("ok, отправлено", Истина, Текст);
КонецФункции
