// @directive=&НаСервере
Процедура ПриОткрытииФормы()
    Если НЕ ЗначениеЗаполнено(Объект.Валюта) Тогда
        Объект.Валюта = "RUB";
    КонецЕсли;
    Если НЕ ЗначениеЗаполнено(Объект.ТипСчёта) Тогда
        Объект.ТипСчёта = "БанковскаяКарта";
    КонецЕсли;
    Если НЕ ЗначениеЗаполнено(Объект.ВключитьВБюджет) Тогда
        Объект.ВключитьВБюджет = true;
    КонецЕсли;
    Если НЕ ЗначениеЗаполнено(Объект.Активный) Тогда
        Объект.Активный = true;
    КонецЕсли;
КонецПроцедуры
