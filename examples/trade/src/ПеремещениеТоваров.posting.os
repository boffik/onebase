// Перемещение между складами с переносом партий по ФИФО.
// С отправителя — расход, на получателя — зеркальный приход с той же ДатойПоставки.

Процедура ОбработкаПроведения()
  Движения.ОстаткиТоваров.Очистить();
  Движения.ПартииТоваров.Очистить();

  ПроверитьЗаполнениеТоваров(this.Товары, "Товары");

  Результаты = СписатьТоварыФИФО(this.СкладОтправитель, this.Организация, this.Товары,
    this.МоментВремени(), "перемещения");

  Индекс = 0;

  Для Каждого Строка Из this.Товары Цикл
    Рез = Результаты[Индекс];
    Индекс = Индекс + 1;

    // Расход со склада-отправителя и зеркальный приход на склад-получатель
    // (та же дата поставки — партия переносится без переоценки)
    ДобавитьДвиженияПартий(Движения.ПартииТоваров, "Расход", Рез.ДвиженияПартий,
      Строка.Номенклатура, this.СкладОтправитель, this.Организация);
    ДобавитьДвиженияПартий(Движения.ПартииТоваров, "Приход", Рез.ДвиженияПартий,
      Строка.Номенклатура, this.СкладПолучатель, this.Организация);

    ДвОР = Движения.ОстаткиТоваров.Добавить();
    ДвОР.ВидДвижения  = "Расход";
    ДвОР.Номенклатура = Строка.Номенклатура;
    ДвОР.Склад        = this.СкладОтправитель;
    ДвОР.Организация  = this.Организация;
    ДвОР.Количество   = Строка.Количество;
    ДвОР.Сумма        = Рез.Себестоимость;

    ДвОП = Движения.ОстаткиТоваров.Добавить();
    ДвОП.ВидДвижения  = "Приход";
    ДвОП.Номенклатура = Строка.Номенклатура;
    ДвОП.Склад        = this.СкладПолучатель;
    ДвОП.Организация  = this.Организация;
    ДвОП.Количество   = Строка.Количество;
    ДвОП.Сумма        = Рез.Себестоимость;
  КонецЦикла;
КонецПроцедуры
