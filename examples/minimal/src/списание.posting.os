Процедура ОбработкаПроведения()
  Движения.ТоварноеДвижение.Очистить();

  Для Каждого Строка Из this.Товары Цикл
    // Проверяем остаток через запрос
    Запрос = Новый Запрос;
    Запрос.Текст =
      "ВЫБРАТЬ
         СУММА(ВЫБОР КОГДА вид_движения = ""Приход"" ТОГДА количество ИНАЧЕ -количество КОНЕЦ) КАК КоличествоОстаток
       ИЗ РегистрНакопления.ТоварноеДвижение
       ГДЕ Номенклатура = &Ном";
    Запрос.УстановитьПараметр("Ном", Строка.Номенклатура);
    Результат = Запрос.Выполнить();

    Остаток = 0;
    Если Результат.Количество() > 0 Тогда
      Остаток = Результат[0].КоличествоОстаток;
    КонецЕсли;

    Если Остаток < Строка.Количество Тогда
      Error("Недостаточно товара: " + Строка.Номенклатура + ". Остаток: " + Остаток + ", требуется: " + Строка.Количество);
    КонецЕсли;

    Дв = Движения.ТоварноеДвижение.Добавить();
    Дв.ВидДвижения = "Расход";
    Дв.Номенклатура = Строка.Номенклатура;
    Дв.Количество = Строка.Количество;
    Дв.Сумма = 0;
  КонецЦикла;
КонецПроцедуры
